# ============================================
# FRONTEND - Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your actual values
# ============================================

# ============================================
# API CONFIGURATION (Required)
# ============================================
# Development: http://localhost:5000/api
# Production: https://api.yourdomain.com/api or https://yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# ============================================
# SITE CONFIGURATION (Required)
# ============================================
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# WHATSAPP BUSINESS (Required)
# ============================================
# Format: +216XXXXXXXX (include country code)
# Used for the "Contact via WhatsApp" button
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ============================================
# NOTES
# ============================================
# 1. All variables starting with NEXT_PUBLIC_ are exposed to the browser
# 2. Never put sensitive data in NEXT_PUBLIC_ variables
# 3. Restart the development server after changing these values
# ============================================

# ============================================
# DEVELOPMENT vs PRODUCTION
# ============================================
# Development (.env.local):
# NEXT_PUBLIC_API_URL=http://localhost:5000/api
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
#
# Production (.env.production):
# NEXT_PUBLIC_API_URL=https://api.ebenor-creation.tn/api
# NEXT_PUBLIC_SITE_URL=https://ebenor-creation.tn
# ============================================

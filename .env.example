# ============================================
# ÉBENOR CRÉATION - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control
# ============================================

# ============================================
# MONGODB CONFIGURATION (Required)
# ============================================
# MongoDB credentials for Docker container
# Generate strong passwords using: openssl rand -base64 32
MONGO_USERNAME=admin
MONGO_PASSWORD=
MONGO_DATABASE=ebenor-creation
MONGO_PORT=27017

# ============================================
# FRONTEND CONFIGURATION (Required)
# ============================================
FRONTEND_PORT=3000
# For development: /api (Next.js API routes)
# For production: /api (Next.js API routes)
NEXT_PUBLIC_API_URL=/api
# For development: http://localhost:3000
# For production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# JWT AUTHENTICATION (Required)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ============================================
# CSRF PROTECTION (Required)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CSRF_SECRET=

# ============================================
# CLOUDINARY - Image/Video Upload (Required)
# ============================================
# Sign up at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# UPLOADTHING - Alternative Upload Service (Optional)
# ============================================
# Sign up at: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=
UPLOADTHING_SECRET=

# ============================================
# EMAIL CONFIGURATION (Required for notifications)
# ============================================
# For Gmail: Enable "App Passwords" in your Google Account settings
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@ebenor-creation.com

# ============================================
# WHATSAPP BUSINESS (Required)
# ============================================
# Format: +216XXXXXXXX (include country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ============================================
# SECURITY CONFIGURATION (Optional)
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# PRODUCTION NOTES
# ============================================
# 1. Change all default passwords
# 2. Use strong, randomly generated secrets
# 3. Never expose MongoDB port (27017) publicly
# 4. Use environment-specific URLs for Site
# 5. Enable HTTPS in production with valid SSL certificates
# 6. Use Docker profiles for production: docker compose --profile production up
# ============================================

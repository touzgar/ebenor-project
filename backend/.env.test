# Variables d'environnement pour les tests
NODE_ENV=test
PORT=5001

# Base de données de test (sera remplacée par MongoDB Memory Server)
MONGODB_URI=mongodb://localhost:27017/ebenor-creation-test

# JWT pour les tests
JWT_SECRET=test-jwt-secret-key
JWT_EXPIRES_IN=1h

# Cloudinary de test (utiliser des valeurs factices)
CLOUDINARY_CLOUD_NAME=test-cloud
CLOUDINARY_API_KEY=test-api-key
CLOUDINARY_API_SECRET=test-api-secret

# Email de test
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=test-password
FROM_EMAIL=test@ebenor-creation.com
ADMIN_EMAIL=admin@ebenor-creation.com

# Configuration de test
BCRYPT_ROUNDS=4
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000
LOG_LEVEL=error
MAX_FILE_SIZE=1048576
ALLOWED_FILE_TYPES=image/jpeg,image/png
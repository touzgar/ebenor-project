# ============================================
# BACKEND - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# ============================================

# ============================================
# APPLICATION CONFIGURATION (Required)
# ============================================
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ============================================
# MONGODB CONNECTION (Required)
# ============================================
# For local development (without Docker):
# MONGODB_URI=mongodb://localhost:27017/ebenor-creation
#
# For Docker development:
# MONGODB_URI=mongodb://admin:your_password@mongodb:27017/ebenor-creation?authSource=admin
#
# For production (MongoDB Atlas or hosted):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ebenor-creation?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/ebenor-creation

# ============================================
# JWT AUTHENTICATION (Required)
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ============================================
# CLOUDINARY - Image/Video Upload (Required)
# ============================================
# Sign up at: https://cloudinary.com/console
# Required for product images and gallery uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# UPLOADTHING - Alternative Upload (Optional)
# ============================================
# Sign up at: https://uploadthing.com/dashboard
# Can be used as alternative to Cloudinary
UPLOADTHING_TOKEN=
UPLOADTHING_APP_ID=
UPLOADTHING_SECRET=

# ============================================
# EMAIL CONFIGURATION (Required)
# ============================================
# For Gmail:
# 1. Enable 2FA on your Google account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use the app password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@ebenor-creation.com
ADMIN_EMAIL=admin@ebenor-creation.com

# ============================================
# SECURITY SETTINGS (Optional)
# ============================================
# Password hashing rounds (10-12 recommended)
BCRYPT_ROUNDS=12
# Rate limiting (900000ms = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING (Optional)
# ============================================
# Options: error, warn, info, debug
LOG_LEVEL=info
LOG_FILE_PATH=./logs

# ============================================
# WHATSAPP BUSINESS (Required)
# ============================================
# Format: +216XXXXXXXX (include country code)
WHATSAPP_NUMBER=

# ============================================
# DEVELOPMENT vs PRODUCTION
# ============================================
# Development:
# - NODE_ENV=development
# - MONGODB_URI=mongodb://localhost:27017/ebenor-creation
# - LOG_LEVEL=debug
#
# Production:
# - NODE_ENV=production
# - MONGODB_URI=mongodb+srv://... (hosted MongoDB)
# - LOG_LEVEL=error
# - Use strong passwords and secrets
# ============================================
